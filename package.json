{
  "name": "data-url-converter",
  "type": "module",
  "version": "1.0.1",
  "author": "Sarkis Andreyan <sarkis@andreyan.com>",
  "license": "MIT",
  "engines": {
    "node": "^24.17.0"
  },
  "private": true,
  "scripts": {
    "start": "vite",
    "build:chromium": "tsc && npm run cleanup && vite build --mode chromium",
    "build:edge": "tsc && npm run cleanup && vite build --mode edge",
    "build:gecko": "tsc && npm run cleanup && vite build --mode gecko",
    "format": "prettier --write \"./**/*.{ts,json,html,md,css,scss}\"",
    "cleanup": "rm -r dist/",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.1.0",
    "@commitlint/config-conventional": "^21.1.0",
    "@crxjs/vite-plugin": "^2.4.0",
    "@eslint/js": "^10.0.1",
    "@types/chrome": "^0.1.43",
    "@types/node": "^25.5.0",
    "eslint": "^10.5.0",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.4",
    "sass-embedded": "^1.100.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.0.0",
    "vite-plugin-zip-pack": "^1.2.4"
  }
}
